{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "noEmitOnError": true,
    "outDir": "../static",
    "paths": {
      "preact": ["./vendor/preact/src/index.d.ts"],
      "preact/hooks": ["./vendor/preact/hooks/src/index.d.ts"],
      "preact/jsx-runtime": ["./vendor/preact/jsx-runtime/src/index.d.ts"]
    },
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["*.ts", "*.tsx", "**/*.ts", "**/*.tsx"],
  "exclude": ["vendor"]
}
