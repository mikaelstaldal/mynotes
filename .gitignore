# Build output
/mynotes
/data

# Generated code (regenerated by build.sh — never committed)
*_gen.go
*.gen.go
web/ts/api/types.ts
web/static/**/*.js
!web/static/vendor/**

# Local agent / editor state
/.claude/settings.local.json
/.claude/tclaude
/.junie
/.idea
/.playwright
/.playwright-mcp
/.playwright-cli

# Task tracking scratch files
/TODO.md
/DOING.md
/DONE.md

# End to end tests
/e2e/node_modules/
/e2e/test-results/
/e2e/playwright-report/

# Vendor rebuild scratch (web/ts/vendor/rebuild.sh) — throwaway, never committed.
# jsdom can't be bundled, so its install tree is vendored as the committed
# deterministic web/ts/vendor/test/jsdom-node_modules.tar.gz; the extracted
# node_modules/ below is ephemeral (restored by web/ts/vendor/test/unpack.sh at
# test time) and must stay out of git.
/web/ts/vendor/node_modules/
/web/ts/vendor/test/node_modules/

/ignored
